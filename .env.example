# ContractIQ environment variables (see SRS Appendix A)
# Copy to .env and fill in. ContractIQ uses REAL AI — an OpenAI key is required
# for embeddings and (by default) for the agents. There is no mock mode.

# ---- Required ----
OPENAI_API_KEY=             # OpenAI key — used for embeddings AND the gpt-4o-mini agents

# ---- LLM provider / models ----
LLM_PROVIDER=auto           # auto | openai | anthropic  (auto -> openai when OPENAI_API_KEY set)
OPENAI_CHAT_MODEL=gpt-4o-mini   # agent model; bump to gpt-4o for highest-quality analysis
EMBEDDING_MODEL=text-embedding-3-small

# ---- Optional: Anthropic (only if LLM_PROVIDER=anthropic) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Infrastructure ----
VECTOR_STORE=faiss          # faiss | chroma | memory
MCP_SERVER_PORT=8001        # Port for the MCP tool server
API_PORT=8000               # Port for the FastAPI backend

# ---- Observability ----
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# ---- Limits / tuning ----
MAX_UPLOAD_MB=50            # Maximum PDF upload size in MB
SIMILARITY_THRESHOLD=0.2    # RAG relevance floor (tuned for text-embedding-3-small)

# ---- Auth (SRS 4.4 — JWT) ----
JWT_SECRET=change-me-to-a-long-random-string   # REQUIRED in prod; signs JWTs
JWT_EXPIRE_MINUTES=1440     # token lifetime (24h)
AUTH_DB_PATH=.data/users.db # SQLite user store (the first signup becomes admin)
